{
  "name": "@command-cabin/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for CommandCabin.",
  "type": "module",
  "main": "./out/main/index.js",
  "types": "./dist/main/index.d.ts",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "doctor": "electron --version",
    "electron:repair": "node ./node_modules/electron/install.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier . --check --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@command-cabin/built-in-plugin-calculator": "workspace:*",
    "@command-cabin/core": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.0.0",
    "electron-vite": "^5.0.0",
    "vite": "^7.1.10"
  }
}
