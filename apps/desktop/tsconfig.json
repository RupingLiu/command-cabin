{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["node", "electron-vite/node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../../packages/core"
    },
    {
      "path": "../../packages/built-in-plugins/calculator"
    },
    {
      "path": "../../packages/built-in-plugins/clipboard-history"
    }
  ]
}
