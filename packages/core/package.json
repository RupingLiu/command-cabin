{
  "name": "@command-cabin/core",
  "version": "0.7.1",
  "private": true,
  "description": "Pure business logic for CommandCabin.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./unitConversion": {
      "types": "./dist/unitConversion.d.ts",
      "import": "./dist/unitConversion.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --config vitest.config.ts",
    "lint": "eslint .",
    "format": "prettier . --check --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@command-cabin/plugin-api": "workspace:*",
    "fuse.js": "^7.3.0"
  }
}
